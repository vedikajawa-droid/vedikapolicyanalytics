test_data_clean <- test_data_clean %>% 
  mutate(predicted_class_50 = ifelse(predicted_prob2 > 0.15,1, 0)) # if predicted probability>0.50, marked as 1 (delinquent)

cm_50_clean <- confusionMatrix(
  as.factor(test_data_clean$predicted_class_50), # predicted delinquency
  as.factor(test_data_clean$delinquent), # actual delinquency
  positive = "1" # telling confusion matrix what the "positive" outcome is
)

print(cm_50_clean)
