## Prepare final model dataframe

```{r final-model-df}

# Drop geometry for modeling (sf objects slow down glm)
final_model_df <- model_df %>%
  st_drop_geometry() %>% 
  # Keep only the variables we'll actually use
  select(
    opa_number,
    year,
    delinquent,         # outcome
    # Lag variables
    lag_delinquent,
    times_delinquent_before,
    # Property characteristics
    log_marketvalue,
    year_built,
    # Census block-group/tract level
    log_medhhince,
    OWN_BURDEN_RATE,
    log_over65,
    log_pov_rate,
    # Spatial features (best 3)
    in_bid,
    log_disthca,
    log_disthotcrime,
    in_emp,
    in_aff_buf,
    #FIXED EFFECT
    Name
  ) %>%
  na.omit()

# Quick sanity check
cat("Rows:", nrow(final_model_df), "\n")
cat("Delinquency rate:", round(mean(final_model_df$delinquent), 3), "\n")
cat("Years in data:", paste(sort(unique(final_model_df$year)), collapse = ", "), "\n")
```

# Part 4: Build Logistic Regression

## Temporal Test/Train Split

```{r}
# Training model data: 2010-2019
train_data <- final_model_df %>% 
  filter(year < 2020)
# Test data: 2020
test_data <- final_model_df %>% 
  filter(year == 2020) %>% 
  filter(lag_delinquent == 0)

cat("Training observations (2010-2019):", nrow(train_data), "\n")
cat("Test observations (2020):", nrow(test_data), "\n")
cat("Training delinquency rate:", round(mean(train_data$delinquent), 3), "\n")
cat("Test delinquency rate:", round(mean(test_data$delinquent), 3), "\n")
```

## Train Logistic Regression Model

```{r}
# lag variables only 
logit_model1 <- glm(
  delinquent ~ lag_delinquent +
    times_delinquent_before,
  data = train_data,
  family = "binomial"
)

summary(logit_model1)

# convert coefficients to odds ratios for better interpretation
exp(coef(logit_model1))

AIC1 <- AIC(logit_model1)
```

```{r}
# + Property characteristics
    
logit_model2 <- glm(
  delinquent ~ lag_delinquent +
    times_delinquent_before +
    log_marketvalue +
    year_built,
  data = train_data,
  family = "binomial"
)

AIC2 <- AIC(logit_model2)

summary(logit_model2)

# convert coefficients to odds ratios for better interpretation
exp(coef(logit_model2))

```

```{r}
# + census

logit_model3 <- glm(
  delinquent ~ lag_delinquent +
    times_delinquent_before +
    log_marketvalue +
    year_built +
    log_medhhince +
    OWN_BURDEN_RATE +
    log_over65 +
    log_pov_rate,
  data = train_data,
  family = "binomial"
)

AIC3 <- AIC(logit_model3)

summary(logit_model3)

# convert coefficients to odds ratios for better interpretation
exp(coef(logit_model3))
```

```{r}
#+ spatial
logit_model4 <- glm(
  delinquent ~ lag_delinquent +
    times_delinquent_before +
    log_marketvalue +
    year_built +
    log_medhhince +
    OWN_BURDEN_RATE +
    log_over65 +
    log_pov_rate + 
    in_bid +
    log_disthca +
    log_disthotcrime +
    in_emp +
    in_aff_buf,
    
  data = train_data,
  family = "binomial"
)

AIC4 <- AIC(logit_model4)

summary(logit_model4)

# convert coefficients to odds ratios for better interpretation
exp(coef(logit_model4))
```

```{r}
#+ FIXED EFFECTS
logit_model5 <- glm(
  delinquent ~ lag_delinquent +
    times_delinquent_before +
    log_marketvalue +
    year_built +
    log_medhhince +
    OWN_BURDEN_RATE +
    log_over65 +
    log_pov_rate + 
    in_bid +
    log_disthca +
    log_disthotcrime +
    in_emp +
    in_aff_buf+
    Name,
    
  data = train_data,
  family = "binomial"
)

AIC5 <- AIC(logit_model5)

summary(logit_model5)
```

## Get predicted probabilities

```{r}
 test_data <- test_data %>% 
  mutate(
    predicted_prob = predict(logit_model5, newdata = test_data, type = "response")
  )

summary(test_data$predicted_prob)

ggplot(test_data, aes(x = predicted_prob, fill = as.factor(delinquent))) +
  geom_histogram(bins = 50, alpha = 0.7, position = "identity") +
  scale_fill_manual(
    values = c("steelblue", "coral"), 
    labels = c("Not Delinquent", "Delinquent")
  ) +
  labs(
    title = "Predicted Probability of Delinquency in 2020", 
    x = "Predicted Probability",
    y = "Count",
    fill = "Actual Outcome"
  )
```

## Confusion Matrix

```{r}
install.packages("caret")
library(caret)

test_data <- test_data %>% 
  mutate(predicted_class_50 = ifelse(predicted_prob > 0.15, 1, 0)) # if predicted probability>0.50, marked as 1 (delinquent)

cm_50 <- confusionMatrix(
  as.factor(test_data$predicted_class_50), # predicted delinquency
  as.factor(test_data$delinquent), # actual delinquency
  positive = "1" # telling confusion matrix what the "positive" outcome is
)

print(cm_50)

# Pull out the key metrics explicitly
cat("\nKey Metrics at Threshold = 0.50:\n")
cat("Sensitivity:", round(cm_50$byClass["Sensitivity"], 3),
    "— of all properties that became delinquent, how many did we catch?\n")
cat("Specificity:", round(cm_50$byClass["Specificity"], 3),
    "— of all properties that stayed current, how many did we correctly spare?\n")
cat("Precision:", round(cm_50$byClass["Precision"], 3),
    "— of properties we flagged, how many actually became delinquent?\n")
cat("Accuracy:", round(cm_50$overall["Accuracy"], 3), "\n")



# How many unique delinquent properties do you actually have?
train_data %>% 
  group_by(delinquent) %>% 
  summarise(n = n(), unique_properties = n_distinct(opa_number))



n_delinquent <- sum(train_data$delinquent == 1)
# n_delinquent should be around 16,058

# 80:20 ratio = 4x non-delinquent
train_balanced <- bind_rows(
  train_data %>% filter(delinquent == 1),
  train_data %>% filter(delinquent == 0) %>% 
    slice_sample(n = n_delinquent*1.5)
)

table(train_balanced$delinquent)
# Should give you roughly:
# 0: ~64,000
# 1: ~16,000
```

```{r}
logit_modelbalanced <- glm(
  delinquent ~ lag_delinquent +
    times_delinquent_before +
    log_marketvalue +
    year_built +
    log_medhhince +
    OWN_BURDEN_RATE +
    log_over65 +
    log_pov_rate + 
    in_bid +
    log_disthca +
    log_disthotcrime +
    in_emp +
    in_aff_buf+
    Name,
    
  data = train_balanced,
  family = "binomial"
)

AIC6 <- AIC(logit_modelbalanced)

summary(logit_modelbalanced)
```

### Balanced Model

```{r}
test_data_clean <- test_data %>%
  filter(Name %in% unique(train_balanced$Name)) %>%
  mutate(
    predicted_prob2 = predict(logit_modelbalanced, newdata = ., type = "response")
  )

summary(test_data_clean$predicted_prob2)

ggplot(test_data_clean, aes(x = predicted_prob2, fill = as.factor(delinquent))) +
  geom_histogram(bins = 50, alpha = 0.7, position = "identity") +
  scale_fill_manual(
    values = c("steelblue", "coral"), 
    labels = c("Not Delinquent", "Delinquent")
  ) +
  labs(
    title = "Predicted Probability of Delinquency in 2020", 
    x = "Predicted Probability",
    y = "Count",
    fill = "Actual Outcome"
  )
```

